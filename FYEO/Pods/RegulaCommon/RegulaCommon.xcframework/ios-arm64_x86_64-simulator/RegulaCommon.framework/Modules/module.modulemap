framework module RegulaCommon {
    umbrella header "RegulaCommon.h"

    export *
    module * { export * }
    
    explicit module Private {

        header "RGLCISSyscalls.h"

        export *
    }
}

module RegulaCommon.Swift {
  header "RegulaCommon-Swift.h"
  requires objc
}
